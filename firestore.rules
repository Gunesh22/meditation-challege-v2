rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Participants can read/write their own data
    match /participants/{phone} {
      allow read, write: if true;
    }
    // Counters are readable by all, writable by all
    match /counters/{doc} {
      allow read, write: if true;
    }
  }
}